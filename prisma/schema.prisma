datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Application {
  id             String   @id @default(cuid())
  userId         String
  username       String

  fullname       String
  birthdate      String
  characterName  String
  type           String
  story          String

  status         String   @default("pending")
  createdAt      DateTime @default(now())
}